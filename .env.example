# Ejemplo de archivo .env para producción Villa Luro Store
# Copia este archivo como .env y completa los valores reales

# Base de datos
DB_HOST=localhost
DB_NAME=nombre_base
DB_USER=usuario
DB_PASS=contraseña
DB_CHARSET=utf8mb4

# SMTP
SMTP_HOST=smtp.tudominio.com
SMTP_PORT=587
SMTP_USER=usuario@tudominio.com
SMTP_PASS=contraseña_real

# URL de la app (ajusta según tu dominio)
APP_URL=https://tudominio.com

# Otros posibles valores
SESSION_SECRET=tu_clave_secreta
UPLOADS_PATH=public/uploads/
# DEBUG=false
